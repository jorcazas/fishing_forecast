# Plantilla de variables de entorno. Copiar a `.env` y rellenar.
# `.env` está en `.gitignore` — nunca commitear.

# === Rutas (opcional; defaults relativos al repo) ===
# Déjalas comentadas para usar los defaults. Una variable vacía (DATA_ROOT=) NO
# pisa el default — el código la trata como ausente.
# DATA_ROOT=
# CONFIGS_ROOT=
# REPORTS_ROOT=
# MODELS_ROOT=

# === Credenciales GlobColour (FTP ftp.hermes.acri.fr) ===
# Solicitar en https://hermes.acri.fr/ — requiere aprobación por email.
GLOBCOLOUR_USER=
GLOBCOLOUR_PASS=

# === Credenciales Copernicus Marine ===
# Registro en https://marine.copernicus.eu/ ; usar el SDK `copernicusmarine`.
COPERNICUS_USER=
COPERNICUS_PASS=

# === S3 con artefactos del borrador 2024 (joblib XGB, .h5 LSTM) ===
# Las CREDENCIALES AWS van en `keys.json` (gitignored), NO aquí. Formato:
#   {"aws_access_key_id": "...", "aws_secret_access_key": "...",
#    "region": "us-east-1" (opcional), "bucket": "mi-bucket" (opcional)}
# El bucket puede ir en keys.json o aquí:
S3_BUCKET_LEGACY=

# === Postgres (solo si se retoma la carga a DB; no necesario en Fase 1) ===
PG_HOST=localhost
PG_DB=cobi
PG_USER=postgres
PG_PASSWORD=
